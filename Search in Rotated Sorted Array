class Solution {
    public int search(int[] nums, int target) {
        int i =0;
        int ans =-1;
        int j=nums.length-1;
        while(i<=j){
            if(nums[i] == target){
              ans = i ;
              break; 
            }
            else if ( nums[j] == target){
                ans = j;
                break;
            }
            else{i++;
            j--;}
        }
        return ans;
    }
}
