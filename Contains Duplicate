class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashMap<Integer, Integer> occurrences = new HashMap<>();
        int z = 0;

        for (int num : nums) {
            occurrences.put(num, occurrences.getOrDefault(num, 0) + 1);
        }

        for (Map.Entry<Integer, Integer> entry : occurrences.entrySet()) {
            if(entry.getValue() != 1){
            return true;
        }
        }

        return false;
    }
}
